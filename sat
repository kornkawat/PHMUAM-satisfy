                const canvas = await html2canvas(tempDiv, { scale: 2, useCORS: true });
                document.body.removeChild(tempDiv);

                const imgData = canvas.toDataURL('image/png');
                const pdf = new jspdf.jsPDF('p', 'mm', 'a4');
                const pdfWidth = pdf.internal.pageSize.getWidth();
                const pageHeight = pdf.internal.pageSize.getHeight();
                
                // คำนวณความสูงของรูปภาพให้สอดคล้องกับความกว้าง A4
                const imgHeight = (canvas.height * pdfWidth) / canvas.width;
                let heightLeft = imgHeight;
                let position = 0;

                // แปะหน้าแรก
                pdf.addImage(imgData, 'PNG', 0, position, pdfWidth, imgHeight);
                heightLeft -= pageHeight;

                // หากเนื้อหายาวเกิน 1 หน้า ให้ขึ้นหน้าใหม่
                while (heightLeft > 0) {
                    position = heightLeft - imgHeight; // เลื่อนตำแหน่ง Y ขึ้นไปเพื่อโชว์ส่วนที่เหลือ
                    pdf.addPage();
                    pdf.addImage(imgData, 'PNG', 0, position, pdfWidth, imgHeight);
                    heightLeft -= pageHeight;
                }

                pdf.save('Executive_Report_AI.pdf');

            } catch (err) {
                console.error(err);
                alert('เกิดข้อผิดพลาดในการสร้าง PDF');
            } finally {
                btn.innerHTML = originalText;
                btn.classList.remove('opacity-50', 'cursor-wait');
            }
        }

        // --- Admin & Auth ---
        function openLoginModal() { document.getElementById('loginModal').classList.remove('hidden'); }
        function closeLoginModal() { 
            document.getElementById('loginModal').classList.add('hidden'); 
            document.getElementById('username').value = '';
            document.getElementById('password').value = '';
        }
        function attemptLogin() {
            const u = document.getElementById('username').value;
            const p = document.getElementById('password').value;
            if (u === 'admin' && p === '1234') {
                isAdmin = true;
                closeLoginModal();
                document.getElementById('loginBtn').classList.add('hidden');
                document.getElementById('logoutBtn').classList.remove('hidden');
                document.getElementById('adminArea').classList.remove('hidden');
                renderAdminTable();
            } else { alert('ข้อมูลเข้าสู่ระบบไม่ถูกต้อง'); }
        }
        function logout() {
            isAdmin = false;
            document.getElementById('loginBtn').classList.remove('hidden');
            document.getElementById('logoutBtn').classList.add('hidden');
            document.getElementById('adminArea').classList.add('hidden');
        }

        // --- CRUD Logic ---
        let currentPage = 1;
        const rowsPerPage = 50;

        function renderAdminTable() {
            const tbody = document.getElementById('dataTableBody');
            tbody.innerHTML = '';
            const start = (currentPage - 1) * rowsPerPage;
            const end = start + rowsPerPage;
            const paginatedData = filteredData.slice(start, end);

            paginatedData.forEach(d => {
                const tr = document.createElement('tr');
                tr.className = "hover:bg-gray-50 transition-colors border-b border-gray-100";
                tr.innerHTML = `
                    <td class="px-5 py-3 whitespace-nowrap text-gray-700">${d.year}</td>
                    <td class="px-5 py-3 whitespace-nowrap text-gray-600">${d.term}</td>
                    <td class="px-5 py-3 whitespace-nowrap text-gray-500 font-mono text-xs">${d.respondent.substring(0,20)}</td>
                    <td class="px-5 py-3 text-gray-800">${d.question}</td>
                    <td class="px-5 py-3 text-center"><span class="px-3 py-1 bg-blue-100 text-brand-blue font-bold rounded-full">${d.score}</span></td>
                    <td class="px-5 py-3 text-center whitespace-nowrap">
                        <button onclick="openEditSingleModal(${d._id})" class="text-blue-500 hover:text-blue-700 mr-3" title="แก้ไข"><i class="fa-solid fa-pen-to-square text-lg"></i></button>
                        <button onclick="deleteData(${d._id})" class="text-red-500 hover:text-red-700" title="ลบ"><i class="fa-solid fa-trash-can text-lg"></i></button>
                    </td>
                `;
                tbody.appendChild(tr);
            });

            const total = filteredData.length;
            document.getElementById('tableInfo').innerText = `แสดง ${total > 0 ? start + 1 : 0} ถึง ${Math.min(end, total)} จาก ${total} รายการ`;
            
            const totalPages = Math.ceil(total / rowsPerPage);
            let pageBtns = '';
            if(currentPage > 1) pageBtns += `<button onclick="changePage(-1)" class="px-3 py-1.5 border rounded hover:bg-gray-50">ก่อนหน้า</button>`;
            if(currentPage < totalPages) pageBtns += `<button onclick="changePage(1)" class="px-3 py-1.5 border rounded hover:bg-gray-50">ถัดไป</button>`;
            document.getElementById('paginationControls').innerHTML = pageBtns;
        }

        function changePage(dir) { currentPage += dir; renderAdminTable(); }

        function closeDataModal() { document.getElementById('dataModal').classList.add('hidden'); }

        function openAddModal() {
            document.getElementById('modalTitle').innerText = 'เพิ่มข้อมูลผู้ประเมินใหม่ (10 ข้อ)';
            document.getElementById('editRowId').value = '';
            document.getElementById('editModeType').value = 'add';
            
            let html = `
                <div class="grid grid-cols-2 gap-4 bg-gray-50 p-4 rounded-lg mb-4 border">
                    <div><label class="block text-sm font-semibold mb-1">ปีการศึกษา</label><input type="text" id="f_year" class="w-full border p-2 rounded" placeholder="เช่น 2566"></div>
                    <div><label class="block text-sm font-semibold mb-1">ภาคเรียน</label><input type="text" id="f_term" class="w-full border p-2 rounded" placeholder="เช่น 1 หรือ 2"></div>
                    <div class="col-span-2"><label class="block text-sm font-semibold mb-1">รหัสผู้ประเมิน (อัตโนมัติหรือกำหนดเอง)</label><input type="text" id="f_res" class="w-full border p-2 rounded" value="USER_${Date.now().toString().slice(-6)}"></div>
                </div>
                <h4 class="font-bold text-brand-blue mb-2">กรอกคะแนน (1-5) ตามหัวข้อ</h4>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            `;
            
            uniqueQuestionsList.forEach((q, i) => {
                html += `
                    <div class="bg-white p-3 border rounded shadow-sm">
                        <label class="block text-xs font-semibold text-gray-700 mb-1 truncate" title="${q}">${q}</label>
                        <input type="number" min="1" max="5" id="f_q_${i}" class="w-full border p-2 rounded font-bold text-brand-blue" value="5">
                        <input type="hidden" id="f_qtext_${i}" value="${q}">
                    </div>
                `;
            });
            html += `</div>`;
            document.getElementById('dynamicFormFields').innerHTML = html;
            document.getElementById('dataModal').classList.remove('hidden');
        }

        function openEditSingleModal(id) {
            document.getElementById('modalTitle').innerText = 'แก้ไขข้อมูล (1 รายการ)';
            document.getElementById('editRowId').value = id;
            document.getElementById('editModeType').value = 'edit_single';
            const item = rawData.find(d => d._id === id);
            
            const html = `
                <div class="grid grid-cols-2 gap-4">
                    <div><label class="block text-sm font-semibold mb-1">ปีการศึกษา</label><input type="text" id="f_year" class="w-full border p-2 rounded" value="${item.year}"></div>
                    <div><label class="block text-sm font-semibold mb-1">ภาคเรียน</label><input type="text" id="f_term" class="w-full border p-2 rounded" value="${item.term}"></div>
                </div>
                <div><label class="block text-sm font-semibold mb-1">ผู้ประเมิน</label><input type="text" id="f_res" class="w-full border p-2 rounded" value="${item.respondent}"></div>
                <div><label class="block text-sm font-semibold mb-1">หัวข้อคำถาม</label><input type="text" id="f_qtext_0" class="w-full border p-2 rounded bg-gray-100" value="${item.question}" readonly></div>
                <div><label class="block text-sm font-semibold mb-1">คะแนน (1-5)</label><input type="number" min="1" max="5" id="f_q_0" class="w-full border p-2 rounded font-bold text-brand-blue" value="${item.score}"></div>
            `;
            document.getElementById('dynamicFormFields').innerHTML = html;
            document.getElementById('dataModal').classList.remove('hidden');
        }

        function saveData() {
            const mode = document.getElementById('editModeType').value;
            const year = document.getElementById('f_year').value.trim();
            const term = document.getElementById('f_term').value.trim();
            const res = document.getElementById('f_res').value.trim();

            if(!year || !term) { alert("กรุณากรอก ปี และ ภาคเรียน"); return; }

            if (mode === 'add') {
                const newEntries = [];
                for(let i=0; i<uniqueQuestionsList.length; i++) {
                    const qText = document.getElementById(`f_qtext_${i}`).value;
                    let score = parseFloat(document.getElementById(`f_q_${i}`).value) || 0;
                    if(score > 5) score = 5; if(score < 1) score = 1;
                    
                    newEntries.push({
                        _id: Date.now() + i,
                        year: year, term: term, respondent: res,
                        question: qText, score: score
                    });
                }
                rawData.push(...newEntries);
                alert("เพิ่มข้อมูล 10 รายการสำเร็จ");
            } else {
                const id = parseInt(document.getElementById('editRowId').value);
                const qText = document.getElementById(`f_qtext_0`).value;
                let score = parseFloat(document.getElementById(`f_q_0`).value) || 0;
                if(score > 5) score = 5; if(score < 1) score = 1;

                const index = rawData.findIndex(d => d._id === id);
                if (index > -1) {
                    rawData[index] = { ...rawData[index], year, term, respondent: res, question: qText, score };
                }
                alert("อัปเดตข้อมูลสำเร็จ");
            }

            closeDataModal();
            extractFilters(); 
            applyFilters();
        }

        function deleteData(id) {
            if (confirm('ยืนยันการลบข้อมูลนี้?')) {
                rawData = rawData.filter(d => d._id !== id);
                extractFilters();
                applyFilters();
            }
        }

        // --- Export CSV / Excel (Admin) ---
        function exportData() {
            if(rawData.length === 0) { alert("ไม่มีข้อมูลสำหรับ Export"); return; }
            const format = document.getElementById('exportFormat').value;
            
            const dataToExport = rawData.map(d => ({
                [keys.year || 'ปีการศึกษา']: d.year,
                [keys.term || 'ภาคเรียน']: d.term,
                [keys.respondent || 'ผู้ประเมิน']: d.respondent,
                [keys.question || 'ข้อคำถาม']: d.question,
                [keys.score || 'คะแนน']: d.score
            }));

            if (format === 'csv') {
                const csvString = "\uFEFF" + Papa.unparse(dataToExport);
                const blob = new Blob([csvString], { type: 'text/csv;charset=utf-8;' });
                const url = URL.createObjectURL(blob);
                const link = document.createElement("a");
                link.href = url;
                link.download = "Teaching_Evaluation_Export.csv";
                document.body.appendChild(link); link.click(); document.body.removeChild(link);
            } else {
                const ws = XLSX.utils.json_to_sheet(dataToExport);
                const wb = XLSX.utils.book_new();
                XLSX.utils.book_append_sheet(wb, ws, "Evaluation_Data");
                XLSX.writeFile(wb, "Teaching_Evaluation_Export.xlsx");
            }
        }

        // --- Export Full Dashboard to PDF ---
        async function exportToPDF() {
            const element = document.getElementById('dashboardContent');
            const btn = document.getElementById('pdfBtn');
            const originalHtml = btn.innerHTML;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-2"></i> สร้าง PDF...';
            btn.classList.add('opacity-70', 'cursor-wait');

            try {
                const ignores = document.querySelectorAll('[data-html2canvas-ignore="true"]');
                ignores.forEach(el => el.style.display = 'none');

                const canvas = await html2canvas(element, { scale: 2, useCORS: true, backgroundColor: '#f8fafc' });

                ignores.forEach(el => el.style.display = '');

                const imgData = canvas.toDataURL('image/png');
                const pdf = new jspdf.jsPDF('p', 'mm', 'a4');
                const pdfWidth = pdf.internal.pageSize.getWidth();
                const pdfHeight = (canvas.height * pdfWidth) / canvas.width;
                
                pdf.addImage(imgData, 'PNG', 0, 10, pdfWidth, pdfHeight);
                pdf.save('Teaching_Evaluation_Dashboard.pdf');
                
            } catch (err) { alert('เกิดข้อผิดพลาดในการสร้าง PDF'); } 
            finally { btn.innerHTML = originalHtml; btn.classList.remove('opacity-70', 'cursor-wait'); }
        }

    </script>
</body>
