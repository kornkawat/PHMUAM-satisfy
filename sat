            "5. ความเหมาะสมของการวัดประเมินผล", "6. การตรงต่อเวลา",
            "7. การประยุกต์ใช้ความรู้", "8. ความกระตือรือร้นในการสอน",
            "9. การจัดบรรยากาศการเรียนรู้", "10. ความพึงพอใจโดยรวม"
        ];
        let uniqueQuestionsList = [];

        // --- Init ---
        document.addEventListener('DOMContentLoaded', () => {
            fetchGoogleSheetData();
        });

        // --- Fetch & Process ---
        function fetchGoogleSheetData() {
            document.getElementById('loadingOverlay').classList.remove('hidden');
            const url = `https://docs.google.com/spreadsheets/d/${GOOGLE_SHEET_ID}/gviz/tq?tqx=out:csv&sheet=${encodeURIComponent(SHEET_NAME)}`;
            
            Papa.parse(url, {
                download: true,
                header: true,
                skipEmptyLines: true,
                complete: function(results) { processIncomingData(results.data); },
                error: function(err) {
                    console.error(err);
                    alert("ไม่สามารถดึงข้อมูลอัตโนมัติจากระบบได้ กรุณาใช้ปุ่ม 'นำเข้า'");
                    document.getElementById('loadingOverlay').classList.add('hidden');
                }
            });
        }

        function handleFileUpload(event) {
            const file = event.target.files[0];
            if (!file) return;
            
            document.getElementById('loadingOverlay').classList.remove('hidden');
            document.getElementById('loadingText').innerText = "กำลังนำเข้าข้อมูล...";
            
            const format = document.getElementById('importFormat').value;
            
            if (format === 'csv' || file.name.endsWith('.csv')) {
                Papa.parse(file, {
                    header: true,
                    skipEmptyLines: true,
                    complete: function(results) { processIncomingData(results.data); }
                });
            } else {
                const reader = new FileReader();
                reader.onload = function(e) {
                    const data = new Uint8Array(e.target.result);
                    const workbook = XLSX.read(data, {type: 'array'});
                    const firstSheet = workbook.SheetNames[0];
                    const json = XLSX.utils.sheet_to_json(workbook.Sheets[firstSheet]);
                    processIncomingData(json);
                };
                reader.readAsArrayBuffer(file);
            }
        }

        function processIncomingData(data) {
            if (!data || data.length === 0) {
                alert("ไม่พบข้อมูล หรือไฟล์ว่างเปล่า");
                document.getElementById('loadingOverlay').classList.add('hidden');
                return;
            }

            const headers = Object.keys(data[0]);
            keys.year = headers.find(h => h.includes('ปี') || h.toLowerCase().includes('year')) || headers[0];
            keys.term = headers.find(h => h.includes('ภาค') || h.includes('เทอม') || h.toLowerCase().includes('term')) || headers[1];
            keys.question = headers.find(h => h.includes('ข้อ') || h.includes('คำถาม') || h.toLowerCase().includes('question')) || headers[2];
            keys.score = headers.find(h => h.includes('คะแนน') || h.includes('ระดับ') || h.toLowerCase().includes('score')) || headers[3];
            keys.respondent = headers.find(h => h.includes('ผู้ประเมิน') || h.includes('รหัส') || h.includes('เวลา') || h.toLowerCase().includes('id') || h.toLowerCase().includes('timestamp')) || 'ID_Gen';

            rawData = data.map((row, index) => {
                let q = row[keys.question] ? String(row[keys.question]).trim() : '';
                q = q.replace(/^0+([1-9])(\.|\s)/, '$1$2');
                
                let s = parseFloat(row[keys.score]);
                if (isNaN(s)) s = 0;
                if (s > 5) s = 5;
                if (s < 1) s = 1;

                return {
                    _id: Date.now() + index,
                    year: String(row[keys.year] || 'ไม่ระบุ').trim(),
                    term: String(row[keys.term] || 'ไม่ระบุ').trim(),
                    question: q,
                    score: s,
                    respondent: row[keys.respondent] ? String(row[keys.respondent]).trim() : `ID_${Math.floor(index/10)}`
                };
            }).filter(r => r.question !== ''); 
            
            const qSet = [...new Set(rawData.map(d => d.question))];
            uniqueQuestionsList = qSet.length >= 10 ? qSet.slice(0, 10) : defaultQuestions;

            extractFilters();
            applyFilters();
            
            document.getElementById('loadingOverlay').classList.add('hidden');
            document.getElementById('fileInput').value = ''; 
        }

        // --- Filters ---
        function extractFilters() {
            uniqueYears = [...new Set(rawData.map(d => d.year))].sort((a,b)=>b-a); 
            uniqueTerms = [...new Set(rawData.map(d => d.term))].sort();
            selectedYears = new Set(uniqueYears);
            selectedTerms = new Set(uniqueTerms);
            renderFilterUI();
        }

        function renderFilterUI() {
            document.getElementById('yearFilters').innerHTML = uniqueYears.map(y => `
                <label class="flex items-center cursor-pointer group">
                    <div class="relative flex items-center">
                        <input type="checkbox" class="custom-checkbox opacity-0 absolute h-5 w-5 cursor-pointer z-10" value="${y}" checked onchange="toggleFilter('year', '${y}')">
                        <div class="bg-white border-2 rounded-md border-gray-300 w-5 h-5 flex flex-shrink-0 justify-center items-center mr-2 group-hover:border-brand-blue transition">
                            <svg class="fill-current hidden w-3 h-3 text-white pointer-events-none" viewBox="0 0 20 20"><path d="M0 11l2-2 5 5L18 3l2 2L7 18z"/></svg>
                        </div>
                    </div>
                    <span class="text-sm font-medium text-gray-700 select-none">${y}</span>
                </label>
            `).join('');

            document.getElementById('termFilters').innerHTML = uniqueTerms.map(t => `
                <label class="flex items-center cursor-pointer group">
                    <div class="relative flex items-center">
                        <input type="checkbox" class="custom-checkbox opacity-0 absolute h-5 w-5 cursor-pointer z-10" value="${t}" checked onchange="toggleFilter('term', '${t}')">
                        <div class="bg-white border-2 rounded-md border-gray-300 w-5 h-5 flex flex-shrink-0 justify-center items-center mr-2 group-hover:border-brand-blue transition">
                            <svg class="fill-current hidden w-3 h-3 text-white pointer-events-none" viewBox="0 0 20 20"><path d="M0 11l2-2 5 5L18 3l2 2L7 18z"/></svg>
                        </div>
                    </div>
                    <span class="text-sm font-medium text-gray-700 select-none">เทอม ${t}</span>
                </label>
            `).join('');
        }

        function toggleFilter(type, value) {
            const set = type === 'year' ? selectedYears : selectedTerms;
            if (set.has(value)) set.delete(value); else set.add(value);
            applyFilters();
        }

        function selectAllFilters() {
            selectedYears = new Set(uniqueYears);
            selectedTerms = new Set(uniqueTerms);
            document.querySelectorAll('#yearFilters input, #termFilters input').forEach(cb => cb.checked = true);
            applyFilters();
        }

        function clearAllFilters() {
            selectedYears.clear();
            selectedTerms.clear();
            document.querySelectorAll('#yearFilters input, #termFilters input').forEach(cb => cb.checked = false);
            applyFilters();
        }

        function applyFilters() {
            filteredData = rawData.filter(d => selectedYears.has(d.year) && selectedTerms.has(d.term));
            updateDashboard();
            if (isAdmin) { currentPage = 1; renderAdminTable(); }
        }

        // --- Dashboard Computation ---
        function updateDashboard() {
            if (filteredData.length === 0) {
                document.getElementById('kpiRespondents').innerText = '0';
                document.getElementById('kpiAvgScore').innerText = '0.00';
                document.getElementById('kpiTopScore').innerText = 'ไม่พบข้อมูล';
                document.getElementById('kpiTopScoreVal').innerText = 'เฉลี่ย 0.00';
                if(pieChartInstance) pieChartInstance.destroy();
                if(lineChartInstance) lineChartInstance.destroy();
                if(barChartInstance) barChartInstance.destroy();
                return;
            }

            const totalRespondents = Math.floor(filteredData.length / 10);
            document.getElementById('kpiRespondents').innerText = totalRespondents.toLocaleString();

            const totalScore = filteredData.reduce((sum, d) => sum + d.score, 0);
            const avgScore = (totalScore / filteredData.length).toFixed(2);
            document.getElementById('kpiAvgScore').innerText = avgScore;

            const questionStats = {};
            filteredData.forEach(d => {
                if (!questionStats[d.question]) questionStats[d.question] = { sum: 0, count: 0 };
                questionStats[d.question].sum += d.score;
                questionStats[d.question].count++;
            });

            const qArray = Object.keys(questionStats).map(q => ({
                question: q,
                avg: questionStats[q].sum / questionStats[q].count
            })).sort((a, b) => b.avg - a.avg);

            if (qArray.length > 0) {
                document.getElementById('kpiTopScore').innerText = qArray[0].question;
                document.getElementById('kpiTopScoreVal').innerText = `เฉลี่ย ${qArray[0].avg.toFixed(2)}`;
            }

            renderBarChart(); // New Bar Chart
            renderPieChart(qArray.slice(0, 10)); 
            renderLineChart();
        }

        // --- Charts ---
        Chart.defaults.font.family = "'Prompt', sans-serif";
        const palette = ['#1e3a8a', '#10b981', '#3b82f6', '#34d399', '#6366f1', '#059669', '#818cf8', '#6ee7b7', '#4338ca', '#a7f3d0'];

        // 1. New Bar Chart (Yearly)
        function renderBarChart() {
            const ctx = document.getElementById('barChart').getContext('2d');
            if (barChartInstance) barChartInstance.destroy();

            // Sort years in ascending order for the chart (oldest to newest left to right)
            const yearsToChart = Array.from(selectedYears).sort();
            
            const yearAverages = yearsToChart.map(year => {
                const yearData = filteredData.filter(d => d.year === year);
                if (yearData.length === 0) return 0;
                const sum = yearData.reduce((acc, val) => acc + val.score, 0);
                return parseFloat((sum / yearData.length).toFixed(2));
            });

            barChartInstance = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: yearsToChart.map(y => `ปีการศึกษา ${y}`),
                    datasets: [{
                        label: 'ความพึงพอใจเฉลี่ย',
                        data: yearAverages,
                        backgroundColor: '#3b82f6', // สีน้ำเงินสว่าง
                        borderRadius: 6,
                        maxBarThickness: 80
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: { 
                            min: 1, max: 5, 
                            title: { display: true, text: 'คะแนนเฉลี่ย', font: { weight: 'bold' } },
                            grid: { color: '#e2e8f0' }
                        },
                        x: { grid: { display: false } }
                    },
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            callbacks: { label: (context) => ` เฉลี่ย: ${context.raw} / 5.00` }
                        }
                    }
                }
            });
        }

        // 2. Pie Chart
        function renderPieChart(qArray) {
            const ctx = document.getElementById('pieChart').getContext('2d');
            if (pieChartInstance) pieChartInstance.destroy();

            const labels = qArray.map(q => q.question.length > 35 ? q.question.substring(0, 35) + '...' : q.question);
            const data = qArray.map(q => q.avg.toFixed(2));

            pieChartInstance = new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: labels,
                    datasets: [{
                        data: data,
                        backgroundColor: palette,
                        borderWidth: 3,
                        borderColor: '#ffffff',
                        hoverOffset: 10
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    layout: { padding: 10 },
                    plugins: {
                        legend: { position: 'right', labels: { font: { size: 11 }, boxWidth: 12 } },
                        tooltip: { callbacks: { label: (context) => ` เฉลี่ย: ${context.raw} / 5.00` } }
                    },
                    cutout: '55%'
                }
            });
        }

        // 3. Line Chart
        function renderLineChart() {
            const ctx = document.getElementById('lineChart').getContext('2d');
            if (lineChartInstance) lineChartInstance.destroy();

            const yearsToChart = Array.from(selectedYears).sort();
            const termsToChart = Array.from(selectedTerms).sort();
            let maxScore = -1;

            yearsToChart.forEach(year => {
                termsToChart.forEach(term => {
                    const filtered = filteredData.filter(d => d.year === year && d.term === term);
                    if (filtered.length > 0) {
                        const avg = parseFloat((filtered.reduce((a, b) => a + b.score, 0) / filtered.length).toFixed(2));
                        if (avg > maxScore) maxScore = avg;
                    }
                });
            });

            const datasets = yearsToChart.map((year, i) => {
                const dataPoints = termsToChart.map(term => {
                    const filtered = filteredData.filter(d => d.year === year && d.term === term);
                    if (filtered.length === 0) return null;
                    return parseFloat((filtered.reduce((a, b) => a + b.score, 0) / filtered.length).toFixed(2));
                });

                const color = palette[i % palette.length];
                return {
                    label: `ปีการศึกษา ${year}`,
                    data: dataPoints,
                    borderColor: color,
                    backgroundColor: color + '20',
                    borderWidth: 3,
                    pointBackgroundColor: (ctx) => ctx.raw === maxScore && ctx.raw !== null ? '#f43f5e' : '#ffffff',
                    pointBorderColor: (ctx) => ctx.raw === maxScore && ctx.raw !== null ? '#be123c' : color,
                    pointRadius: (ctx) => ctx.raw === maxScore && ctx.raw !== null ? 10 : 5,
                    pointHoverRadius: (ctx) => ctx.raw === maxScore && ctx.raw !== null ? 12 : 7,
                    pointBorderWidth: (ctx) => ctx.raw === maxScore && ctx.raw !== null ? 3 : 2,
                    fill: true,
                    tension: 0.3
                };
            });

            lineChartInstance = new Chart(ctx, {
                type: 'line',
                data: { labels: termsToChart.map(t => `ภาคเรียน ${t}`), datasets: datasets },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: { min: 1, max: 5, title: { display: true, text: 'คะแนน', font: { weight: 'bold' } } },
                        x: { grid: { display: false } }
                    },
                    plugins: {
                        legend: { position: 'top', labels: { usePointStyle: true } },
                        tooltip: {
                            callbacks: {
                                label: (ctx) => {
                                    const isMax = ctx.raw === maxScore ? ' (สูงสุด)' : '';
                                    return ` ${ctx.dataset.label}: ${ctx.raw} ${isMax}`;
                                }
                            }
                        }
                    }
                }
            });
        }

        // --- AI Executive Report (Gemini) ---
        async function generateAIReport() {
            const btn = document.getElementById('aiBtn');
            const contentDiv = document.getElementById('aiReportContent');
            const textDiv = document.getElementById('aiText');
            const exportBtns = document.getElementById('aiExportButtons');
            
            if(filteredData.length === 0) {
                alert("ไม่มีข้อมูลสำหรับวิเคราะห์ กรุณาตรวจสอบตัวกรองข้อมูล");
                return;
            }

            exportBtns.classList.add('hidden'); // ซ่อนปุ่ม export ระหว่างโหลด
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-2"></i> กำลังวิเคราะห์...';
            btn.classList.add('opacity-75', 'cursor-wait');
            contentDiv.classList.remove('hidden');
            textDiv.innerHTML = '<p class="text-center text-gray-500 py-10"><i class="fa-solid fa-robot fa-bounce text-3xl mb-3"></i><br>AI กำลังประมวลผลข้อมูลและเขียนรายงาน...</p>';

            try {
                const apiKey = ""; 
                const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
                
                const totalRes = document.getElementById('kpiRespondents').innerText;
                const avgScore = document.getElementById('kpiAvgScore').innerText;
                const topQ = document.getElementById('kpiTopScore').innerText;
                
                const questionStats = {};
                filteredData.forEach(d => {
                    if (!questionStats[d.question]) questionStats[d.question] = { sum: 0, count: 0 };
                    questionStats[d.question].sum += d.score;
                    questionStats[d.question].count++;
                });
                const qSummary = Object.keys(questionStats).map(q => 
                    `${q}: ${(questionStats[q].sum / questionStats[q].count).toFixed(2)}`
                ).join("\n");

                const prompt = `ในฐานะผู้เชี่ยวชาญด้านการวิเคราะห์ข้อมูลและพัฒนาการศึกษา กรุณาเขียน "รายงานสรุปสำหรับผู้บริหาร (Executive Report)" จากข้อมูลการประเมินการสอนต่อไปนี้ สรุปให้กระชับ เป็นมืออาชีพ (ภาษาไทย)

ข้อมูลภาพรวม:
- จำนวนผู้ตอบประเมิน: ${totalRes} คน
- คะแนนความพึงพอใจเฉลี่ยรวม: ${avgScore} จาก 5 คะแนน
- หัวข้อที่ได้คะแนนสูงสุด: ${topQ}

ข้อมูลคะแนนเฉลี่ยรายข้อ:
${qSummary}

กรุณาเขียนรายงานโดยแบ่งเป็น 4 หัวข้อหลัก:
1. ภาพรวมการประเมิน
2. จุดเด่นและสิ่งที่ทำได้ดี
3. ประเด็นที่ควรได้รับการพัฒนา (ดูจากข้อที่คะแนนต่ำ)
4. ข้อเสนอแนะเชิงกลยุทธ์สำหรับผู้บริหาร`;

                const payload = { contents: [{ parts: [{ text: prompt }] }] };
                const retries = 5;
                const backoffs = [1000, 2000, 4000, 8000, 16000];
                let resultText = "";

                for (let i = 0; i < retries; i++) {
                    try {
                        const response = await fetch(url, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(payload)
                        });
                        if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);
                        const result = await response.json();
                        resultText = result.candidates?.[0]?.content?.parts?.[0]?.text || "เกิดข้อผิดพลาดในการแปลผลจาก AI";
                        break;
                    } catch (error) {
                        if (i === retries - 1) throw error;
                        await new Promise(res => setTimeout(res, backoffs[i]));
                    }
                }

                textDiv.innerHTML = marked.parse(resultText);
                exportBtns.classList.remove('hidden'); // แสดงปุ่ม export เมื่อเสร็จสิ้น

            } catch (err) {
                console.error(err);
                textDiv.innerHTML = '<p class="text-red-500 font-bold p-4">ไม่สามารถเชื่อมต่อกับ AI ได้ในขณะนี้ กรุณาลองใหม่อีกครั้ง (Environment อาจไม่รองรับ API Key)</p>';
            } finally {
                btn.innerHTML = '<i class="fa-solid fa-robot mr-2"></i> สร้างใหม่';
                btn.classList.remove('opacity-75', 'cursor-wait');
            }
        }

